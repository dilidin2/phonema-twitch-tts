# Twitch Configuration
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_BOT_USERNAME=your_bot_username # (use you channel name if you don't have a separate account for the bot)

# IMPORTANT: Get your BROADCASTER_ID (numeric channel ID, not username!)
# Find it at: https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/
TWITCH_BROADCASTER_ID=your_broadcaster_id

# Server Configuration
PORT=8990
HOST=0.0.0.0
MAX_QUEUE_SIZE=10
REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
